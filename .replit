modules = ["python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["arrow-cpp", "cacert", "cairo", "cargo", "chromedriver", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "lcms2", "libcxx", "libffi", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssl", "pgadmin4", "pkg-config", "qhull", "rustc", "tcl", "tk", "xsimd", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "RAG Demo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Tests"

[[workflows.workflow]]
name = "RAG Demo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "LD_PRELOAD=/lib/x86_64-linux-gnu/libstdc++.so.6 python cli.py pipeline data/reports/sample_report.txt"

[[workflows.workflow]]
name = "Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "LD_PRELOAD=/lib/x86_64-linux-gnu/libstdc++.so.6 python -m pytest tests/ -q"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "ui/app.py", "--server.port", "5000", "--server.address", "0.0.0.0"]
